{{!
    @template block_openai_chat/control_bar

    This template renders the control_bar.

    Example context (json):
    {
        "logging_enabled": boolean, true if logging is enabled in the plugin settings
        "is_edit_mode": boolean; true if edit mode is active
        "pix_popout": relative url of the popout pix to the root of moodle
        "pix_send": relative url of the send pix to the root of moodle
        "pix_refresh": relative url of the refresh pix to the root of moodle
    }
}}


{{^is_edit_mode}}
    {{#logging_enabled}}
        <div title='{{#str}}loggingenabled, block_openai_chat{{/str}}' class='recording'></div>
    {{/logging_enabled}}
    <button class='openai_input_popout_btn' title="{{#str}}popout, block_openai_chat {{/str}}" id="popout">
        <span class="icon-expand">
            {{#pix}} arrow-up-right-from-square1, block_openai_chat {{/pix}}
        </span>
        
        <span class="icon-close">
            {{#pix}} close-window, block_openai_chat {{/pix}}
        </span>
    </button>
{{/is_edit_mode}}
<div id="control_bar">
    <div class="openai_input_bar" id="input_bar">
        <textarea rows=1 id="openai_input" placeholder="{{#str}}askaquestion, block_openai_chat{{/str}}" type="text" name="message"></textarea>
        <button class='openai_input_submit_btn' title="{{#str}} submit {{/str}}" id="go">
            <img src="{{{config.wwwroot}}}{{{ pix_send }}}" class='openai_input_submit_btn_icon'/>
        </button>
    </div>
    <button class='openai_input_refresh_btn' title="{{#str}}new_chat, block_openai_chat {{/str}}" id="refresh">
        <img src="{{{config.wwwroot}}}{{{ pix_refresh }}}" class='openai_input_refresh_btn_icon' />
    </button>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {

    // 1. DEKLARASI VARIABEL (Cukup satu kali saja)
    const chatLog = document.getElementById('openai_chat_log');
    const refreshBtn = document.getElementById('refresh');
    const popoutBtn = document.getElementById('popout');
    const chatBlock = document.querySelector('.block_openai_chat'); 
    
    // Nama kunci penyimpanan di memori browser
    const STORAGE_KEY = 'moodle_openai_chat_history';

    // 2. FITUR PENYIMPANAN RIWAYAT OBROLAN
    if (chatLog) {
        // Saat halaman dibuka: Muat ulang riwayat jika ada
        const savedChat = sessionStorage.getItem(STORAGE_KEY);
        if (savedChat) {
            chatLog.innerHTML = savedChat;
            chatLog.scrollTop = chatLog.scrollHeight;
        }

        // Saat ngobrol: Rekam otomatis setiap ada perubahan di kotak chat
        const observer = new MutationObserver(function() {
            sessionStorage.setItem(STORAGE_KEY, chatLog.innerHTML);
        });
        observer.observe(chatLog, { childList: true, subtree: true });
    }

    // 3. FITUR TOMBOL REFRESH / NEW CHAT
    if (refreshBtn) {
        refreshBtn.addEventListener('click', function() {
            sessionStorage.removeItem(STORAGE_KEY);
            
            setTimeout(function() {
                if (chatLog) {
                    const onboardingHTML = `
                        <div class="openai_message bot onboarding_message">
                            <p> {{ msg_onboarding }} </p>
                        </div>
                    `;
                    chatLog.innerHTML = onboardingHTML;
                }
            }, 100); 
        });
    }

    // 4. FITUR UBAH LABEL TOMBOL POPOUT
    if (popoutBtn && chatBlock) {
        popoutBtn.addEventListener('click', function() {
            // Tunggu 50 milidetik agar JS bawaan Moodle selesai menambahkan class
            setTimeout(function() {
                if (chatBlock.classList.contains('expanded')) {
                    popoutBtn.setAttribute('title', 'Close chat window'); 
                } else {
                    popoutBtn.setAttribute('title', 'Open chat window'); 
                }
            }, 50);
        });
    }
});
</script>